# Supabase credentials - get these from your Supabase project dashboard
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Server-only key — bypasses RLS for /api/subscribe inserts.
# NEVER prefix with NEXT_PUBLIC_. Set in Vercel as a server env var.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# --- Resolvr support agent LLM backend (see docs/resolvr-spec.md) ---
# Resolvr drafts replies via Ollama (local) first, then a cloud API key, then a
# deterministic offline template. All optional: with none set, the offline
# template still produces a grounded reply so the public demo never breaks.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
# Any OpenAI-compatible endpoint. Leave LLM_API_KEY blank to disable the cloud tier.
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_API_MODEL=gpt-4o-mini
